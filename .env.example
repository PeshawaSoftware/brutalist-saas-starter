# Core application
VITE_APP_ID=your_app_id
VITE_OAUTH_PORTAL_URL=https://your-auth-portal.example.com
OAUTH_SERVER_URL=https://your-oauth-server.example.com
JWT_SECRET=change_me
DATABASE_URL=mysql://user:password@localhost:3306/brutalist_saas
OWNER_OPEN_ID=your_owner_open_id

# Server runtime
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
REQUEST_BODY_LIMIT=1mb

# Optional built-in service integrations
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
